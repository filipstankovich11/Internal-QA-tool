{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/score.py": {
      "runtime": "python3.9",
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/send-digest",
      "schedule": "0 8 * * 1"
    }
  ],
  "rewrites": [
    { "source": "/api/score",        "destination": "/api/score" },
    { "source": "/api/views",        "destination": "/api/score" },
    { "source": "/api/view-tickets", "destination": "/api/score" },
    { "source": "/api/send-digest",  "destination": "/api/score" },
    { "source": "/(.*)",             "destination": "/index.html" }
  ]
}
